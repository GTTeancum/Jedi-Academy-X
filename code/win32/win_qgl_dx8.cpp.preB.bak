/*
 * win_qgl_dx8.cpp
 *
 * Thin adapter binding JKA's qgl_* function pointer table to xquake's
 * gl_fakegl.cpp (FakeGL).  Per RENDERER_GRAFT.md: gl_fakegl.cpp is the
 * only renderer; this file is plumbing.
 *
 * Original 7000-line hand-rolled D3D8 renderer body has been removed.
 * What remains:
 *   - The 350 qgl_* function-pointer definitions (storage)
 *   - QGL_Init / QGL_Shutdown that bind the pointers to FakeGL exports
 *     (or to typed no-op stubs where FakeGL doesn't implement the call)
 *   - GLW_Init / GLW_Shutdown that drive FakeGL's wgl* lifecycle
 *   - GLimp_Init / GLimp_EndFrame / GLimp_Shutdown / GLimp_LogComment
 *   - Stubs for JKA-specific render passes (renderObject_*,
 *     CreateVertexShader / CreatePixelShader)
 *   - glw_state allocation (struct shape preserved so code/renderer/
 *     compiles unchanged; runtime behaviour reduced to FakeGL-via-qgl)
 */

/* Define APIENTRY = __stdcall BEFORE any include.
 * qgl.h (pulled in via tr_local.h) has:
 *     #ifndef APIENTRY
 *     #define APIENTRY
 *     #endif
 * If we don't beat that to the punch, all 350 qgl_* function pointers get
 * declared as cdecl, while gl_fakegl.cpp's exports (which see APIENTRY via
 * windef.h) are stdcall.  Mismatch → linker fails on cdecl _glAlphaFunc when
 * gl_fakegl provides stdcall _glAlphaFunc@8.  Setting it ourselves first
 * makes qgl.h's #ifndef a no-op so qgl_* are stdcall and match. */
#define APIENTRY __stdcall
#define WINAPI   __stdcall

// leave this as first line for PCH reasons...
#include "../server/exe_headers.h"

#include <float.h>
#include "../renderer/tr_local.h"
#include "glw_win_dx8.h"
#include "win_local.h"

#ifdef _XBOX
#include <xtl.h>
#include <xb_log.h>
#endif

/* StaticTextureAllocator is referenced from outside this TU (xbox_texture_man).
 * The renderer's draw paths (which exercise it) won't fire before Phase 3, but
 * the symbol must exist to link. */
#include "xbox_texture_man.h"
StaticTextureAllocator gTextures;

extern void Z_SetNewDeleteTemporary(bool);

/* Forward decl for FakeGL's diagnostic logger (defined in quake_stubs.cpp,
 * routes to XBLog).  Used by GLW_Init's P0 probe to verify the path. */
extern "C" void Con_Printf( char *fmt, ... );

/* Texture bridge — handles JKA's DDS / S3TC compressed texture extensions
 * by decompressing in CPU before forwarding to FakeGL as RGBA. */
#include "qgl_texture_bridge.h"

void QGL_EnableLogging( qboolean enable );

/* qgl_console.h (pulled in via glw_win_dx8.h) does #undef APIENTRY at line 43.
 * Restore __stdcall here so the qgl_* storage definitions below match the
 * extern declarations in qgl.h (also __stdcall thanks to our top-of-file
 * pre-define). */
#undef APIENTRY
#undef WINAPI
#define APIENTRY __stdcall
#define WINAPI   __stdcall

/* =========================================================================
 *  qgl_* function pointer storage (350 declarations)
 *  ---
 *  These were the original storage definitions in the hand-rolled renderer.
 *  Preserved verbatim so the rest of the engine (which #include "qgl.h" and
 *  calls qgl* directly) still links.  Each one defaults to a no-op stub on
 *  QGL_Init; the few that FakeGL implements are bound to FakeGL's static
 *  exports below.
 * ========================================================================= */

