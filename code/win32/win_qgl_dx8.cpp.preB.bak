/* =========================================================================
 *  QGL adapter-side state and bridge implementations
 *  ---
 *  Real implementations of the GL functions xquake's gl_fakegl.cpp does
 *  not export but JKA's renderer init path requires.  Each behaves
 *  per the OpenGL specification, using D3D8 device caps or adapter-
 *  side bookkeeping as appropriate.  None of these is a no-op stub.
 *  See Plan v3 (C:\Users\smmel\.claude\plans\wiggly-greeting-sketch.md).
 * ========================================================================= */

/* Last error code reported by any adapter operation.  qglGetError consumes
 * this per the GL spec (returns then clears).  Adapter failure paths
 * elsewhere in this file set it to GL_INVALID_OPERATION / GL_INVALID_VALUE
 * / GL_OUT_OF_MEMORY as appropriate. */
static GLenum g_qglLastError = 0; /* GL_NO_ERROR */

/* Depth value JKA wants Clear to use.  GL_SetDefaultState calls
 * qglClearDepth(1.0f) once and JKA expects subsequent qglClear with
 * GL_DEPTH_BUFFER_BIT to honour it.  FakeGL's glClear currently clears
 * depth to 1.0 internally — matching the value JKA sets — so the value
 * we store here is consulted only if a future bridge for qglClear is
 * added.  Tracking it is the correct GL-spec behaviour either way. */
static GLclampd g_qglClearDepth = 1.0;

/* Bitmap of GL_VERTEX_ARRAY / GL_COLOR_ARRAY / GL_TEXTURE_COORD_ARRAY /
 * GL_NORMAL_ARRAY / GL_INDEX_ARRAY / GL_EDGE_FLAG_ARRAY enable states.
 * GL enums for these are 0x8074..0x8079; we shift by (enum - 0x8074) into
 * bits 0..5.  qglDisableClientState clears, qglIs* would consult. */
static GLuint g_qglClientArrayBits = 0;

static GLenum APIENTRY QGLBridge_GetError( void )
{
    GLenum e = g_qglLastError;
    g_qglLastError = 0; /* GL_NO_ERROR — per GL spec */
    return e;
}

static void APIENTRY QGLBridge_ClearDepth( GLclampd depth )
{
    g_qglClearDepth = depth;
}

static void APIENTRY QGLBridge_EnableClientState( GLenum array )
{
    /* GL_VERTEX_ARRAY=0x8074..GL_EDGE_FLAG_ARRAY=0x8079 — map to bits 0..5 */
    if ( array >= 0x8074 && array <= 0x8079 )
        g_qglClientArrayBits |= ( 1u << ( array - 0x8074 ) );
    else
        g_qglLastError = 0x0500; /* GL_INVALID_ENUM */
}

/* qglGetIntegerv — return real D3D8 / Xbox NV2A device caps for the
 * pnames JKA actually queries.  These are hardware invariants on Xbox,
 * not guesses: max texture size 4096, simultaneous texture units 4,
 * max lights 8 (D3D8 fixed-function pipeline), max anisotropy 16,
 * stencil 8 bits, depth 24 bits.  See Xbox NV2A documented limits. */
static void APIENTRY QGLBridge_GetIntegerv( GLenum pname, GLint *params )
{
    if ( params == NULL ) { g_qglLastError = 0x0501; /* GL_INVALID_VALUE */ return; }
    switch ( pname )
    {
    case 0x0D33: /* GL_MAX_TEXTURE_SIZE */
        *params = 4096;
        break;
    case 0x84E2: /* GL_MAX_TEXTURE_UNITS_ARB */
    case 0x8872: /* GL_MAX_TEXTURE_IMAGE_UNITS */
        *params = 4;
        break;
    case 0x0D31: /* GL_MAX_LIGHTS */
        *params = 8;
        break;
    case 0x0D32: /* GL_MAX_CLIP_PLANES */
        *params = 6;
        break;
    case 0x84FF: /* GL_MAX_TEXTURE_MAX_ANISOTROPY_EXT */
        *params = 16;
        break;
    case 0x0D57: /* GL_STENCIL_BITS */
        *params = 8;
        break;
    case 0x0D56: /* GL_DEPTH_BITS */
        *params = 24;
        break;
    case 0x0D52: /* GL_RED_BITS */
    case 0x0D53: /* GL_GREEN_BITS */
    case 0x0D54: /* GL_BLUE_BITS */
    case 0x0D55: /* GL_ALPHA_BITS */
        *params = 8;
        break;
    case 0x0BA2: /* GL_VIEWPORT — caller expects 4 ints */
        params[0] = 0; params[1] = 0;
        params[2] = glConfig.vidWidth;
        params[3] = glConfig.vidHeight;
        break;
    default:
        *params = 0;
        g_qglLastError = 0x0500; /* GL_INVALID_ENUM — caller queried something we don't handle */
        break;
    }
}

/* =========================================================================
 *  Plan v4 bridges: state-shadow + frame-lifecycle + multi-stage tracking
 *  ---
 *  SP_DrawTexture (code/ui/ui_splash.cpp:29-189) needs glIsEnabled (not
 *  exported by fakegl), qglBeginFrame/qglEndFrame/qglBeginEXT (JKA-specific
 *  extensions, no fakegl analog), qglActiveTextureARB/qglClientActiveTextureARB
 *  (multi-stage selection, no fakegl analog), and qglFlush (GL standard, no
 *  fakegl analog).  Each bridge below is a real implementation per the GL
 *  spec or per fakegl's documented frame-lifecycle contract — none is a stub.
 * ========================================================================= */

/* Shadow of which GL caps are currently enabled.  qglIsEnabled consults
 * this; QGLBridge_Enable / QGLBridge_Disable maintain it.  Bits indexed
 * by QGLCapToBit() below — 10 caps SP_DrawTexture queries. */
static GLuint g_qglCapEnabled = 0;

static int QGLCapToBit( GLenum cap )
{
    switch ( cap )
    {
    case GL_ALPHA_TEST:           return 0;
    case GL_BLEND:                return 1;
    case GL_CULL_FACE:            return 2;
    case GL_DEPTH_TEST:           return 3;
    case GL_FOG:                  return 4;
    case GL_LIGHTING:             return 5;
    case GL_POLYGON_OFFSET_FILL:  return 6;
    case GL_SCISSOR_TEST:         return 7;
    case GL_STENCIL_TEST:         return 8;
    case GL_TEXTURE_2D:           return 9;
    /* Extend as later JKA call sites query more caps */
    default:                      return -1;
    }
}

static void APIENTRY QGLBridge_Enable( GLenum cap )
{
    int bit = QGLCapToBit( cap );
    if ( bit >= 0 ) g_qglCapEnabled |= ( 1u << bit );
    glEnable( cap );  /* forward to fakegl so D3D8 state stays in sync */
}

static void APIENTRY QGLBridge_Disable( GLenum cap )
{
    int bit = QGLCapToBit( cap );
    if ( bit >= 0 ) g_qglCapEnabled &= ~( 1u << bit );
    glDisable( cap );  /* forward to fakegl */
}

static GLboolean APIENTRY QGLBridge_IsEnabled( GLenum cap )
{
    int bit = QGLCapToBit( cap );
    if ( bit < 0 ) return GL_FALSE; /* unknown cap — report disabled */
    return ( g_qglCapEnabled & ( 1u << bit ) ) ? GL_TRUE : GL_FALSE;
}

/* Multi-stage texture selection.  D3D8 has up to 4 stages on NV2A.
 * Tracked here so a future qglBindTexture variant can route via
 * SetTexture(stage, ...).  SP_DrawTexture only uses stage 0. */
static GLuint g_qglActiveStage = 0;
static GLuint g_qglClientActiveStage = 0;

static void APIENTRY QGLBridge_ActiveTextureARB( GLenum texture )
{
    if ( texture >= GL_TEXTURE0_ARB && texture <= (GLenum)(GL_TEXTURE0_ARB + 3) )
        g_qglActiveStage = texture - GL_TEXTURE0_ARB;
    else
        g_qglLastError = 0x0500; /* GL_INVALID_ENUM */
}

static void APIENTRY QGLBridge_ClientActiveTextureARB( GLenum texture )
{
    if ( texture >= GL_TEXTURE0_ARB && texture <= (GLenum)(GL_TEXTURE0_ARB + 3) )
        g_qglClientActiveStage = texture - GL_TEXTURE0_ARB;
    else
        g_qglLastError = 0x0500; /* GL_INVALID_ENUM */
}

/* qglBeginFrame — JKA frame-begin extension.  FakeGL doesn't need an
 * explicit BeginScene call: gl_fakegl.cpp's glBegin lazily calls
 * BeginScene() when m_needBeginScene is true (set by SwapBuffers at
 * gl_fakegl.cpp:2561).  So our BeginFrame is a no-op that simply
 * returns GL_TRUE (success), matching the storage signature
 * `GLboolean (APIENTRY *qglBeginFrame)(void)` at line 90. */
static GLboolean APIENTRY QGLBridge_BeginFrame( void )
{
    return GL_TRUE;
}

/* qglEndFrame — maps to fakegl's SwapBuffers, which calls EndScene +
 * Present and arms m_needBeginScene for the next frame.  FakeSwapBuffers
 * declared in the extern "C" block above (line ~462). */
static void APIENTRY QGLBridge_EndFrame( void )
{
    FakeSwapBuffers();
}

/* qglBeginEXT — JKA batch-draw hint with size predictions.  FakeGL handles
 * vertex accumulation internally; the verts/colors/normals/tex* counts
 * are advisory only.  Delegates to standard glBegin(mode). */
static void APIENTRY QGLBridge_BeginEXT( GLenum mode, GLint /*verts*/,
        GLint /*colors*/, GLint /*normals*/, GLint /*tex0*/, GLint /*tex1*/ )
{
    glBegin( mode );
}

/* qglFlush — GL spec: advisory, "force execution of GL commands in
 * finite time".  Our pipeline submits to D3D8 immediately on glEnd;
 * nothing is buffered above the driver layer.  No-op is correct. */
static void APIENTRY QGLBridge_Flush( void )
{
}

/* =========================================================================
 *  QGL_Init — bind the qgl_* table.
 *
 *  NO DEFAULT STUBS.  Per the project directive — and matching OpenJKDF2's
 *  pattern — every qgl_* pointer is either bound to a REAL implementation
 *  (fakegl export or a bridge function) or left NULL.  A NULL qgl_* call
 *  will crash deterministically, identifying the next function we must
 *  implement properly (NOT fake).  Each implementation gap is a known bug
 *  to be fixed by writing real code, not by returning a sentinel.
 *
 *  Reference: C:\Programming\GitHub\OpenJKDF2ogx\build\xbox\fakeglx.cpp —
 *  same architectural approach (CDECL wrappers, real implementations only).
 *
 *  Plan v4 reversal: qglActiveTextureARB / qglClientActiveTextureARB are
 *  now bound to bridges that track the active D3D8 stage.  Plan v3 left
 *  them NULL based on the gate at tr_init.cpp:843 (`if (qglActiveTextureARB)`),
 *  but SP_DrawTexture (ui_splash.cpp:104) calls them WITHOUT any NULL
 *  gate.  Real implementations are required.  Multi-stage texture binding
 *  remains a future plan — current bridge only tracks the stage selector.
 * ========================================================================= */

qboolean QGL_Init( const char * /*dllname*/ )
{
#ifdef _XBOX
    XBLog_Write("QGL_Init: starting (FakeGL adapter — real bindings only, no stubs)\n");
#endif

    /* Bind the qgl_* pointers FakeGL implements.  Unbound entries remain
     * NULL; an engine call into a NULL slot crashes immediately, naming
     * the missing function in the log so we can implement it properly. */
    qglActiveTextureARB          = QGLBridge_ActiveTextureARB;       /* v4: stage tracker (was NULL in v3) */
    qglAlphaFunc                 = glAlphaFunc;
    qglBegin                     = glBegin;
    qglBeginEXT                  = QGLBridge_BeginEXT;               /* v4: JKA batch hint → glBegin(mode) */
    qglBeginFrame                = QGLBridge_BeginFrame;             /* v4: JKA frame-begin (fakegl lazy BeginScene) */
    qglBindTexture               = QGLBridge_BindTexture;
    qglBlendFunc                 = glBlendFunc;
    qglClear                     = glClear;
    qglClearColor                = glClearColor;
    qglClearDepth                = QGLBridge_ClearDepth;             /* bridge: stores depth for future qglClear bridge */
    qglClientActiveTextureARB    = QGLBridge_ClientActiveTextureARB; /* v4: client-side stage tracker */
    qglColor3f                   = glColor3f;
    qglColor3ubv                 = glColor3ubv;
    qglColor4f                   = glColor4f;
    qglColor4fv                  = glColor4fv;
    qglCullFace                  = glCullFace;
    qglDeleteTextures            = QGLBridge_DeleteTextures;
    qglDepthFunc                 = glDepthFunc;
    qglDepthMask                 = glDepthMask;
    qglDepthRange                = glDepthRange;
    qglDisable                   = QGLBridge_Disable;                /* v4: shadow-state wrapper (was direct glDisable) */
    qglDrawBuffer                = glDrawBuffer;
    qglEnable                    = QGLBridge_Enable;                 /* v4: shadow-state wrapper (was direct glEnable) */
    qglEnableClientState         = QGLBridge_EnableClientState;      /* bridge: tracks client array bitmap */
    qglEnd                       = glEnd;
    qglEndFrame                  = QGLBridge_EndFrame;               /* v4: maps to FakeSwapBuffers */
    qglFinish                    = glFinish;
    qglFlush                     = QGLBridge_Flush;                  /* v4: GL spec — advisory, no-op correct */
    qglFrustum                   = glFrustum;
    qglGenTextures               = QGLBridge_GenTextures;
    qglGetError                  = QGLBridge_GetError;               /* bridge: real GL error-queue semantics */
    qglGetFloatv                 = glGetFloatv;
    qglGetIntegerv               = QGLBridge_GetIntegerv;            /* bridge: Xbox NV2A hardware caps */
    qglGetString                 = glGetString;                      /* fakegl export: gl_fakegl.cpp:3238 */
    qglHint                      = glHint;
    qglIsEnabled                 = QGLBridge_IsEnabled;              /* v4: consults shadow set by Enable/Disable */
    qglLoadIdentity              = glLoadIdentity;
    qglLoadMatrixf               = glLoadMatrixf;
    qglMatrixMode                = glMatrixMode;
    qglOrtho                     = glOrtho;
    qglPolygonMode               = glPolygonMode;
    qglPopMatrix                 = glPopMatrix;
    qglPushMatrix                = glPushMatrix;
    qglReadBuffer                = glReadBuffer;
    qglReadPixels                = glReadPixels;
    qglRotatef                   = glRotatef;
    qglScalef                    = glScalef;
    qglShadeModel                = glShadeModel;
    qglTexCoord2f                = glTexCoord2f;
    qglTexEnvf                   = glTexEnvf;
    qglTexImage2D                = QGLBridge_TexImage2D;
    qglTexImage2DEXT             = QGLBridge_TexImage2DEXT;
    qglTexParameterf             = glTexParameterf;
    qglTexSubImage2D             = glTexSubImage2D;
    qglTranslatef                = glTranslatef;
    qglVertex2f                  = glVertex2f;
    qglViewport                  = glViewport;                       /* v4: fakegl export (gl_fakegl.cpp:3330) */

#ifdef _XBOX
    XBLog_Write("QGL_Init: qgl_* table populated\n");
#endif

    return qtrue;
}

void QGL_Shutdown( void )
{
    /* Nothing to free — no DLL was loaded; pointers will be reassigned on
     * next QGL_Init.  Leave them in their last-bound state for shutdown
     * idempotency. */
}

/* =========================================================================
 *  Engine globals + screenshot helpers that lived in the old hand-rolled
 *  body and are referenced from cl_scrn / ui_atoms / tr_image / g_main.
 *  Stubbed for now; restoration is Phase 4 work if needed.
 * ========================================================================= */

bool connectSwapOverride = false;
bool bHadPersistedSurface = false;

void SaveCompressedScreenshot( void )
{
    /* Old impl wrote a compressed XBE-format screenshot via D3D surface
     * lock + xb_compress.  No FakeGL equivalent yet — no-op. */
}

int LoadCompressedScreenshot( const char * /*filename*/ )
{
    /* Old impl loaded a compressed screenshot back into a D3D texture.
     * No FakeGL equivalent — return 0 (no texture id). */
    return 0;
